# Database
DATABASE_URL=sqlite:///./linkbio.db
SECRET_KEY=dev-secret-change-in-production

# Frontend (CORS + email links)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Paystack — get keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_MONTHLY_BASE_AMOUNT_NGN=500
# Yearly price = 12× monthly minus this discount (default 15% → ₦5,100/year at ₦500/mo)
PAYSTACK_YEARLY_DISCOUNT_PERCENT=15
BILLING_PAST_DUE_GRACE_DAYS=3
BILLING_MANUAL_RENEWAL_REMINDER_DAYS=3

# Avatar storage — Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Transactional email — Brevo (https://app.brevo.com)
BREVO_API_KEY=
# Set true locally to enable POST /api/dev/test-email
DEV_ROUTES_ENABLED=false
